					"minecraft:collision_box": {
						"origin": [ -6, 0, -6 ],
						"size": [ 12, 3, 12 ]
					},
					"minecraft:transformation": {
						"rotation": [
							0,
							0,
							0
						]
					}
				}
			},
			{
				"condition": "query.block_state('minecraft:block_face') == 'down'",
				"components": {
					"minecraft:geometry": "geometry.redstone_link_floor_rec",
					"minecraft:selection_box": {
						"origin": [ -6, 0, -6 ],
						"size": [ 12, 3, 12 ]
					},
					"minecraft:collision_box": {
						"origin": [ -6, 0, -6 ],
						"size": [ 12, 3, 12 ]
					},
					"minecraft:transformation": {
						"rotation": [
							180,
							0,
							0
						]
					}
				}
			}
		]
